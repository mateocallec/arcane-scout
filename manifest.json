{
  "manifest_version": 3,
  "name": "Arcane Scout — API Pentesting Toolkit",
  "short_name": "Arcane Scout",
  "version": "1.1.0",
  "description": "A professional Chrome DevTools extension for API traffic inspection and web pentesting.",
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "arcane-scout@mateocallec.com",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "action": {
    "default_title": "Help & Documentation",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "contextMenus",
    "storage",
    "cookies"
  ],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
